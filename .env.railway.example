# Railway Production Environment Variables
# Copy this file to .env and update with actual values before deploying to Railway

# ═══════════════════════════════════════════════════════════════════════════
# DATABASE CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════
DB_HOST=your-mysql-host.railway.app
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your-password-here
DB_NAME=smartshelf
DB_DIALECT=mysql

# ═══════════════════════════════════════════════════════════════════════════
# SERVER CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════
PORT=3000
NODE_ENV=production

# ═══════════════════════════════════════════════════════════════════════════
# CORS CONFIGURATION - CRITICAL FOR PRODUCTION
# ═══════════════════════════════════════════════════════════════════════════
# Comma-separated list of allowed origins for CORS requests
# This MUST include your frontend production URL
ALLOWED_ORIGINS=https://smartshelfx-production.up.railway.app,https://smartshelfx-frontend-production.up.railway.app

# ═══════════════════════════════════════════════════════════════════════════
# JWT CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-here
JWT_EXPIRES_IN=24h

# ═══════════════════════════════════════════════════════════════════════════
# EMAIL CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-here
SENDER_EMAIL=noreply@smartshelfx.com
SENDER_NAME=SmartShelfX

# ═══════════════════════════════════════════════════════════════════════════
# FRONTEND URLs
# ═══════════════════════════════════════════════════════════════════════════
FRONTEND_URL=https://smartshelfx-production.up.railway.app
APP_URL=https://smartshelfx-production.up.railway.app

# ═══════════════════════════════════════════════════════════════════════════
# ML SERVICE CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════
ML_SERVICE_URL=https://your-ml-service.up.railway.app
